{
  "entities": {
    "SoilReading": {
      "title": "Soil Reading",
      "description": "A single telemetry reading from the ESP32 sensor suite",
      "type": "object",
      "properties": {
        "nitrogen": { "type": "number", "description": "Nitrogen level (mg/kg)" },
        "phosphorus": { "type": "number", "description": "Phosphorus level (mg/kg)" },
        "potassium": { "type": "number", "description": "Potassium level (mg/kg)" },
        "temperature": { "type": "number", "description": "Temperature in Celsius" },
        "humidity": { "type": "number", "description": "Relative humidity percentage" },
        "latitude": { "type": "number", "description": "GPS Latitude" },
        "longitude": { "type": "number", "description": "GPS Longitude" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the reading was recorded" },
        "source": { "type": "string", "description": "Origin of the data (e.g., ESP32)" }
      },
      "required": ["nitrogen", "phosphorus", "potassium", "temperature", "humidity", "timestamp"]
    },
    "LogEntry": {
      "title": "Log Entry",
      "description": "Manual notes or observations added by the user",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The note content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the note was created" },
        "type": { "type": "string", "enum": ["observation", "action", "alert"], "description": "Category of the log" }
      },
      "required": ["content", "timestamp", "type"]
    },
    "CustomCrop": {
      "title": "Custom Crop Profile",
      "description": "User-added plant profile discovered via AI",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "idealNPK": { 
          "type": "object",
          "properties": { 
            "n": { "type": "number" }, 
            "p": { "type": "number" }, 
            "k": { "type": "number" } 
          }
        },
        "idealTemp": {
          "type": "object",
          "properties": { 
            "min": { "type": "number" }, 
            "max": { "type": "number" } 
          }
        },
        "idealHumidity": {
          "type": "object",
          "properties": { 
            "min": { "type": "number" }, 
            "max": { "type": "number" } 
          }
        },
        "description": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "idealNPK", "idealTemp", "idealHumidity"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User-specific settings and layout configurations",
      "type": "object",
      "properties": {
        "dashboardLayout": { "type": "array", "description": "Custom widget arrangement" },
        "tabOrder": { "type": "array", "description": "Custom sidebar tab order" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User-specific layout and settings"
    },
    "/readings": {
      "schema": "SoilReading",
      "description": "Historical log of all sensor readings"
    },
    "/latest/status": {
      "schema": "SoilReading",
      "description": "The most recent reading for real-time dashboard display"
    },
    "/logs": {
      "schema": "LogEntry",
      "description": "User-generated field notes"
    },
    "/custom_crops": {
      "schema": "CustomCrop",
      "description": "Community-generated crop profiles"
    }
  }
}

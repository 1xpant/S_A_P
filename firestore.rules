rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // PILLAR 0: Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    // PILLAR 4 & 6: Verified Identity
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // PILLAR 3: Path Variable Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // PILLAR 2: Validation Blueprints
    function isValidSoilReading(data) {
      return data.keys().hasAll(['nitrogen', 'phosphorus', 'potassium', 'temperature', 'humidity', 'timestamp', 'source']) &&
             data.nitrogen is number &&
             data.phosphorus is number &&
             data.potassium is number &&
             data.temperature is number &&
             data.humidity is number &&
             data.timestamp is string && data.timestamp.size() <= 64 &&
             data.source is string && data.source.size() <= 64 &&
             (data.keys().hasAll(['latitude', 'longitude']) ? (data.latitude is number && data.longitude is number) : true);
    }

    // ===============================================================
    // PILLAR 1: Data Collections
    // ===============================================================

    match /readings/{readingId} {
      // Allow reading history only to verified users (reduces scraping risk)
      allow read: if isVerified();
      // Allow creation with strict schema validation
      allow create: if isValidSoilReading(incoming());
      // ONLY allow deletion for admins or specific power users if app grows,
      // but for now, require verification at minimum.
      allow delete: if isVerified();
    }

    match /latest/status {
      // Allow status view for signed-in members (initial landing)
      // Transition to isVerified() for sensitive actions
      allow read: if isSignedIn();
      // Single-document status singleton update
      allow write: if isVerified() && isValidSoilReading(incoming());
    }

    match /test/connection {
      allow read: if true;
    }

    match /logs/{logId} {
      allow read: if true;
      // PILLAR 5: Individual Resource Protection
      allow create: if isVerified() && 
                      incoming().userId == request.auth.uid &&
                      incoming().content is string && incoming().content.size() <= 5000;
      allow update, delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /custom_crops/{cropId} {
      allow read: if true;
      allow create: if isVerified() && 
                      incoming().createdBy == request.auth.uid &&
                      incoming().name is string && incoming().name.size() <= 100;
      allow update, delete: if isVerified() && existing().createdBy == request.auth.uid;
    }

    match /users/{userId} {
      // PILLAR 4: User-specific tier logic
      allow read, write: if isVerified() && request.auth.uid == userId;
    }
  }
}
